{
  "name": "@siegetag/sheet-map",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Generic Mapbox map + bottom sheet shell for React web apps",
  "sideEffects": [
    "./dist/styles.css",
    "./src/import-sheet-map-styles.ts"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./dist/styles.css",
    "./shell": {
      "types": "./src/shell/index.ts",
      "default": "./src/shell/index.ts"
    },
    "./camera": {
      "types": "./src/camera/index.ts",
      "default": "./src/camera/index.ts"
    }
  },
  "files": [
    "dist/styles.css",
    "styles/build.css",
    "src",
    "package.json"
  ],
  "scripts": {
    "build:styles": "tailwindcss -i ./styles/build.css -o ./dist/styles.css --minify",
    "prepare": "pnpm run build:styles",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@siegetag/ui": "workspace:*",
    "mapbox-gl": "^3.24.1",
    "react-map-gl": "^8.1.1",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@napi-rs/canvas": "^1.0.0",
    "@tailwindcss/cli": "^4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/geojson": "^7946.0.16",
    "@types/mapbox-gl": "^3.5.0",
    "@types/react": "^19.1.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^29.0.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "^7.9.4",
    "tailwindcss": "^4",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  }
}
