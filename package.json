{
  "name": "@siegetag/sheet-map",
  "version": "0.2.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "description": "Mapbox map + bottom sheet shell for React (fresh rebuild)",
  "repository": {
    "type": "git",
    "url": "https://github.com/UltimateTag-Studios/sheet-map.git"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": [
    "LICENSE",
    "dist/style.css",
    "styles/sheet-map.css",
    "src",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm run build:styles",
    "build:styles": "node ./scripts/build-styles.mjs",
    "prepare": "pnpm run build:styles",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "mapbox-gl": "^3.24.1",
    "react-map-gl": "^8.1.1"
  },
  "peerDependencies": {
    "@siegetag/sheet": "^0.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@siegetag/sheet": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/mapbox-gl": "^3.5.0",
    "@types/react": "^19.1.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^29.0.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "^7.9.4",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  }
}
